# DATABASE CONNECTION (Supabase)
# ⚠️ IMPORTANT: Do NOT use the Project URL (https://...). 
# Use the "Connection String" URI from Supabase settings (Settings > Database > Connection string > URI).
SUPABASE_URL=postgresql://postgres:[YOUR-DATABASE-PASSWORD]@db.xxxx.supabase.co:5432/postgres

# Amazon Seller Central Credentials
AMAZON_EMAIL=your-email@example.com
AMAZON_PASSWORD=your-password
AMAZON_TOTP_SECRET=your-totp-secret-key

# Bot Configuration
HEADLESS_MODE=true
# On windows/mac localhost, set PORT to something else if 3000 is occupied
PORT=3000
NODE_ENV=development

# Optional: AI Configuration
GEMINI_API_KEY=
