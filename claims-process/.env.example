# Database Configuration
# You can use a local PostgreSQL instance or a remote one like Supabase
SUPABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxx.supabase.co:6543/postgres

# Amazon Seller Central Credentials
AMAZON_EMAIL=your-email@example.com
AMAZON_PASSWORD=your-password
AMAZON_TOTP_SECRET=your-totp-secret-key

# Bot Configuration
HEADLESS_MODE=true
NODE_ENV=development

# Optional: AI Configuration if needed
GEMINI_API_KEY=your-gemini-api-key
