generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String      @id @default(uuid())
  email          String      @unique
  name           String?
  role           Role
  itemsProcessed Int         @default(0)
  accuracyRate   Float       @default(100.0)
  alertLevel     AlertLevel?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  alertsResolved Alert[]     @relation("AlertResolver")
  alertsTargeted Alert[]     @relation("AlertTarget")
}

model Manifest {
  id                String             @id @default(uuid())
  trackingId        String             @unique
  status            PackageState
  marketplace       Marketplace        @default(AMAZON)
  orderId           String?
  removalOrderId    String?
  expectedDate      DateTime?
  receivedAt        DateTime?
  receivedBy        String?
  inspectedBy       String?
  claimId           String?
  createdAt         DateTime           @default(now())
  courierName       String?
  alerts            Alert[]
  evidences         Evidence[]
  orders            Order[]
  trackingSnapshots ShipmentTracking[]
}

model Order {
  marketplace        Marketplace
  platformOrderId    String      @id
  requestDate        DateTime?
  totalAmount        Float?
  totalQuantity      Int?
  fulfillmentChannel String?
  fulfillmentId      String?
  manifestId         String?
  trackingNumber     String?
  manifest           Manifest?   @relation(fields: [manifestId], references: [id])
}

model ShipmentTracking {
  trackingNumber    String    @id
  manifestId        String?
  courierName       String?
  courierSlug       String?
  latestStatus      String?
  latestLocation    String?
  scheduledDelivery DateTime?
  checkpointCount   Int       @default(0)
  checkpoints       Json?
  rawText           String?
  fetchedAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  manifest          Manifest? @relation(fields: [manifestId], references: [id])

  @@index([manifestId])
}

model Reimbursement {
  id                      String    @id @default(uuid())
  returnItemId            String    @unique
  platformReimbursementId String?   @unique
  amountReimbursed        Float
  currency                String
  reimbursementReason     String?
  status                  String
  filedAt                 DateTime?
  resolvedAt              DateTime?
}

model Evidence {
  id              String       @id @default(uuid())
  lpn             String       @unique
  orderId         String?
  orderDriveLink  String?
  lpnDriveLink    String?
  type            EvidenceType
  rawReference    String?
  uploadedByEmail String?
  manifestId      String?
  returnItemId    String?
  claimReason     String?
  claimSubReason  String?
  createdAt       DateTime     @default(now())
  status          String?
  manifest        Manifest?    @relation(fields: [manifestId], references: [id])
}

model Alert {
  id              String     @id @default(uuid())
  level           AlertLevel
  type            String
  title           String
  description     String
  manifestId      String?
  targetUserId    String?
  resolved        Boolean    @default(false)
  resolvedById    String?
  resolvedAt      DateTime?
  resolution      String?
  sopAcknowledged Boolean    @default(false)
  sopViewedAt     DateTime?
  createdAt       DateTime   @default(now())
  manifest        Manifest?  @relation(fields: [manifestId], references: [id])
  resolvedBy      User?      @relation("AlertResolver", fields: [resolvedById], references: [id])
  targetUser      User?      @relation("AlertTarget", fields: [targetUserId], references: [id])
}

model CronJobState {
  jobKey        String    @id
  lastRunAt     DateTime?
  lastSuccessAt DateTime?
  lastError     String?
  updatedAt     DateTime  @updatedAt
}

model ItemStatus {
  lpn            String   @id @default(uuid())
  status         String
  recoveryType   String?
  orderId        String?
  lpnDriveLink   String?
  orderDriveLink String?
  createdAt      DateTime @default(now())
}

model MissingItem {
  id              String   @id @default(uuid())
  orderId         String
  fnsku           String
  missingQuantity Int
  createdAt       DateTime @default(now())

  @@unique([orderId, fnsku])
}

model AMZRemovalOrder {
  id                String    @id @default(uuid())
  orderId           String    @map("order-id")
  requestDate       DateTime? @map("request-date")
  orderSource       String?   @map("order-source")
  orderType         String?   @map("order-type")
  serviceSpeed      String?   @map("service-speed")
  orderStatus       String?   @map("order-status")
  lastUpdatedDate   DateTime? @map("last-updated-date")
  sku               String   @map("sku")
  fnsku             String?   @map("fnsku")
  disposition       String?   @map("disposition")
  requestedQuantity Int?      @map("requested-quantity")
  cancelledQuantity Int?      @map("cancelled-quantity")
  disposedQuantity  Int?      @map("disposed-quantity")
  shippedQuantity   Int?      @map("shipped-quantity")
  inProcessQuantity Int?      @map("in-process-quantity")
  removalFee        Float?    @map("removal-fee")
  currency          String?   @map("currency")

  @@map("AMZ_removal_orders")

  @@unique([orderId, sku], name: "orderId_sku")
}

model AMZRemovalShipment {
  id              String    @id @default(uuid())
  requestDate     DateTime? @map("request-date")
  orderId         String?   @map("order-id")
  shipmentDate    DateTime? @map("shipment-date")
  sku             String   @map("sku")
  fnsku           String?   @map("fnsku")
  disposition     String?   @map("disposition")
  shippedQuantity Int?      @map("shipped-quantity")
  carrier         String?   @map("carrier")
  trackingNumber  String?   @map("tracking-number")
  processedAt     DateTime?
  shipmentStatus  String?   @map("shipment-status")

  @@map("AMZ_removal_shipments")
}

model AMZReimbursement {
  reimbursementId             String    @id @map("reimbursement-id")
  approvalDate                DateTime? @map("approval-date")
  caseId                      String?   @map("case-id")
  amazonOrderId               String?   @map("amazon-order-id")
  reason                      String?   @map("reason")
  sku                         String?   @map("sku")
  fnsku                       String?   @map("fnsku")
  asin                        String?   @map("asin")
  productName                 String?   @map("product-name")
  condition                   String?   @map("condition")
  currencyUnit                String?   @map("currency-unit")
  amountPerUnit               Float?    @map("amount-per-unit")
  amountTotal                 Float?    @map("amount-total")
  quantityReimbursedCash      Int?      @map("quantity-reimbursed-cash")
  quantityReimbursedInventory Int?      @map("quantity-reimbursed-inventory")
  quantityReimbursedTotal     Int?      @map("quantity-reimbursed-total")
  originalReimbursementId     String?   @map("original-reimbursement-id")
  originalReimbursementType   String?   @map("original-reimbursement-type")

  @@map("AMZ_reimbursements")
}

model AMZCustomerReturn {
  lpn                 String    @id @map("license-plate-number")
  returnDate          DateTime? @map("return-date")
  orderId             String?   @map("order-id")
  sku                 String?   @map("sku")
  asin                String?   @map("asin")
  fnsku               String?   @map("fnsku")
  productName         String?   @map("product-name")
  quantity            Int?      @map("quantity")
  fulfillmentCenterId String?   @map("fulfillment-center-id")
  detailedDisposition String?   @map("detailed-disposition")
  reason              String?   @map("reason")
  customerComments    String?   @map("customer-comments")
  removalOrderType    String?   @map("removal-order-type")

  @@map("AMZ_customer_returns")
}

model ReturnPrimeReturn {
  id               String   @id
  request_number   String?
  request_type     String?
  status           String?
  channel          String?
  order_id         String?
  order_name       String?
  recevied_status  Boolean?
  rejected_status  Boolean?
  archived_status  Boolean?
  refund_status    String?
  sku              String?
  traking_number   String?
  quantity         Int?
  actual_amount    Float?
  image_src        String?

  @@index([order_id])
  @@index([traking_number])
  @@map("return_prime_returns")
}

model ShiprocketReturn {
  id             String      @id
  channelId      String?
  requestNumber  String?
  channelOrderId String?
  requestType    String?
  status         String?
  channel        String?
  orderId        String?
  orderName      String?
  orderCreatedAt DateTime?
  fulfillmentId  String?
  deliveryStatus String?
  deliveryDate   DateTime?
  customerEmail  String?
  postalCode     String?
  awb            String?
  courierName    String?
  courierSlug    String?
  productId      String?
  price          Float?
  shipmentId     String?
  shipmentsId    String?
  trackingNumber String?
  rtoAwb         String?
  returnAwb      String?
  etd            DateTime?
  rtoInitiatedDate DateTime?
  orderItemsSku  String?
  packageId      String?
  sku            String?
  productName    String?
  quantity       Int?
  amount         Float?
  marketplace    Marketplace @default(SHOPIFY)
  rawPayload     Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([orderId])
  @@index([channelId])
  @@index([channelOrderId])
  @@index([shipmentId])
  @@index([trackingNumber])
  @@map("shiprocket_returns")
}

model ShopifyReturnTracking {
  trackingNumber    String      @id
  sourceType        String
  sourceId          String
  marketplace       Marketplace @default(SHOPIFY)
  courierName       String?
  courierSlug       String?
  latestStatus      String?
  latestLocation    String?
  scheduledDelivery DateTime?
  checkpointCount   Int         @default(0)
  checkpoints       Json?
  rawText           String?
  fetchedAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  orderId           String?

  @@index([sourceType, sourceId])
  @@index([marketplace])
  @@map("shopify_return_tracking")
}

model ReturnItem {
  lpn                 String    @id
  returnDate          DateTime? @map("return-date")
  sku                 String?   @map("sku")
  asin                String?   @map("asin")
  fnsku               String?   @map("fnsku")
  productName         String?   @map("product-name")
  quantity            Int?      @map("quantity")
  fulfillmentCenterId String?   @map("fulfillment-center-id")
  detailedDisposition String?   @map("detailed-disposition")
  reason              String?   @map("reason")
  customerComments    String?   @map("customer-comments")
  removalOrderType    String?   @map("removal-order-type")
  marketplace         String?   @default("amazon")
  orderId             String?
  itemPrice           Float?

  @@map("ReturnItem")
}

model ClaimsStatus {
  id           Int      @id @default(autoincrement())
  orderId      String   @unique
  trackingId   String?
  claimId      String   @default("")
  status       String   @default("unclaimed")
  botLogReason String?  @map("bot_log_reason")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("claims_status")
}

model QcStatus {
  sku           String  @id
  targetCount   Int     @map("target_count")
  quantityCount Int     @default(0) @map("quantity_count")
  status        String?

  @@map("qc_status")
}

model SampleRecovery {
  lpn           String  @id
  sku           String
  damageType    String  @map("damage_type")
  status        String  @default("recovery")
  isRefurbished Boolean @default(false)

  @@map("sample_recovery")
}

model claims_all {
  lpn            String    @id
  orderId        String?
  trackingId     String?
  sku            String?
  fnsku          String?
  productName    String?
  channel        String?
  status         String?   @default("unclaimed")
  type           String?
  driveLink      String?
  orderDriveLink String?
  createdAt      DateTime? @db.Timestamptz(6)
  qty            Int?
}

enum Role {
  SUPER_ACCESS
  ADMIN
  RECEIVER
  INSPECTOR
  CLAIMS_SPECIALIST
  RECOVERER
  QC_AGENT
}

enum Marketplace {
  AMAZON
  SHOPIFY
}

enum PackageState {
  EXPECTED
  IN_TRANSIT
  LOST_IN_TRANSIT
  AT_DOCK
  IN_INSPECTION
  INSPECTED
  CLAIMS_STAGING
  CLAIM_RESOLVED
  RECOVERED_TO_INVENTORY
}

enum ItemCondition {
  GOOD_SELLABLE
  PACKAGING_DAMAGED
  PRODUCT_DAMAGED
  WRONG_ITEM
  MISSING
  BAD_FAKE_PRODUCT
}

enum AlertLevel {
  L1
  L2
  L3
  L4
}

enum EvidenceType {
  RECEIVER_REJECTION
  INSPECTOR_REJECTION
  INSPECTION_VIDEO
  PRODUCT_DAMAGE_PHOTO
}
