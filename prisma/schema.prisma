generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ACCESS
  ADMIN
  RECEIVER
  INSPECTOR
  CLAIMS_SPECIALIST
}

enum Marketplace {
  AMAZON
  SHOPIFY
}

enum PackageState {
  EXPECTED
  LOST_IN_TRANSIT
  AT_DOCK
  IN_INSPECTION
  INSPECTED
  CLAIMS_STAGING
  CLAIM_RESOLVED
  RECOVERED_TO_INVENTORY
}

enum ItemCondition {
  GOOD_SELLABLE
  PACKAGING_DAMAGED
  PRODUCT_DAMAGED
  WRONG_ITEM
  MISSING
  BAD_FAKE_PRODUCT
}

// Mirrors Amazon IDR portal defect types — inspector selects when marking BAD
enum InspectorDefectType {
  WAREHOUSE_DAMAGE
  CARRIER_DAMAGE
  CUSTOMER_DAMAGE
  DEFECTIVE
  EXPIRED
  WRONG_ITEM_RECEIVED
  MISSING_PARTS_ACCESSORIES
  NOT_AS_DESCRIBED
  FAKE_COUNTERFEIT
}

enum HandshakeType {
  COURIER_TO_RECEIVER
  RECEIVER_TO_INSPECTOR
}

enum AlertLevel {
  L1
  L2
  L3
  L4
}

enum EvidenceType {
  RECEIVER_REJECTION
  INSPECTION_VIDEO
  PRODUCT_DAMAGE_PHOTO
}

model ProductStatus {
  id         String       @id @default("current")
  lpn        String
  condition  ItemCondition
  updatedAt  DateTime     @updatedAt
}

model User {
  id               String       @id @default(uuid())
  email            String       @unique
  name             String?
  role             Role
  itemsProcessed   Int          @default(0)
  accuracyRate     Float        @default(100.0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  handshakesSent   Handshake[]  @relation("Sender")
  handshakesRecv   Handshake[]  @relation("Receiver")
  inspections      Inspection[]
  evidences        Evidence[]
  alertsTargeted   Alert[]      @relation("AlertTarget")
  alertsResolved   Alert[]      @relation("AlertResolver")
}

model Manifest {
  id               String       @id @default(uuid())
  trackingId       String       @unique
  status           PackageState
  marketplace      Marketplace?
  courierName      String?
  removalOrderId   String?        // Amazon removal order ID linking to RemovalShipment
  expectedDate     DateTime?
  receivedAt       DateTime?
  createdAt        DateTime     @default(now())

  handshakes       Handshake[]
  inspection       Inspection?
  orders           Order[]
  disputes         Dispute[]
  evidences        Evidence[]
  alerts           Alert[]
  removalShipments RemovalShipment[]
}

model Handshake {
  id               String        @id @default(uuid())
  manifestId       String
  senderId         String?
  receiverId       String
  type             HandshakeType
  timestamp        DateTime

  manifest         Manifest      @relation(fields: [manifestId], references: [id])
  sender           User?         @relation("Sender", fields: [senderId], references: [id])
  receiver         User          @relation("Receiver", fields: [receiverId], references: [id])
}

model Inspection {
  id                 String    @id @default(uuid())
  manifestId         String    @unique
  inspectorId        String
  totalItemsExpected Int
  totalItemsScanned  Int
  isMissingItems     Boolean
  evidenceUrl        String?
  completedAt        DateTime

  manifest           Manifest  @relation(fields: [manifestId], references: [id])
  inspector          User      @relation(fields: [inspectorId], references: [id])
}

model Order {
  marketplace        Marketplace
  platformOrderId    String       @id // Amazon order-id or Shopify order_id
  purchaseDate       DateTime
  customerName       String?
  totalAmount        Float?
  fulfillmentChannel String?      // FBA / FBM / Shopify
  imageUrl           String?      // Product image URL
  manifestId         String?
  manifest           Manifest?   @relation(fields: [manifestId], references: [id])
  claimId               String?   // claim identifier after claim processing

  returnItems        ReturnItem[]
}

model ReturnItem {
  orderId              String
  sku                  String
  lpn                  String              @id // From AMZ_customer_returns.license-plate-number
  asin                 String?             // From AMZ_customer_returns.asin
  fnsku                String?             // From AMZ_customer_returns.fnsku
  productName          String?             // Added to support product name per LPN
  quantity             Int
  returnReason         String              // From AMZ_customer_returns.reason
  customerComments     String?             // From AMZ_customer_returns.customer-comments
  amazonDisposition    String?             // From AMZ_customer_returns.detailed-disposition (SELLABLE, DAMAGED, etc.)
  condition            ItemCondition?      // Inspector's grade (GOOD_SELLABLE, PRODUCT_DAMAGED, etc.)
  inspectorDefectType  InspectorDefectType? // Amazon claim defect type dropdown — set when marking BAD
  claimReason          String?
  claimSubReason       String?
  itemPrice            Float?              // Per-unit price for reimbursement calculation

  order                Order               @relation(fields: [orderId], references: [platformOrderId])
  reimbursement        Reimbursement?
  evidences            Evidence[]
}

model Reimbursement {
  id                      String     @id @default(uuid())
  returnItemId            String     @unique
  platformReimbursementId String?    @unique
  amountReimbursed        Float
  currency                String
  reimbursementReason     String?
  status                  String
  filedAt                 DateTime?
  resolvedAt              DateTime?

  returnItem              ReturnItem @relation(fields: [returnItemId], references: [lpn])
}

model Dispute {
  id            String    @id @default(uuid())
  manifestId    String
  type          String    // e.g. "L1_DOCK_ALERT", "L3_MISSING_ITEM"
  evidenceUrl   String?
  resolved      Boolean   @default(false)
  createdAt     DateTime  @default(now())

  manifest      Manifest  @relation(fields: [manifestId], references: [id])
}

model RemovalShipment {
  id               String    @id @default(uuid())
  removalOrderId   String
  trackingNumber   String
  shipmentDate     DateTime
  sku              String
  shippedQuantity  Int
  disposition      String
  manifestId       String?   // Link to Manifest via tracking number match

  manifest         Manifest? @relation(fields: [manifestId], references: [id])

  @@unique([trackingNumber, sku])
}

model Evidence {
  id             String       @id @default(uuid())
  lpn            String       @unique
  orderId        String?
  orderDriveLink String?
  lpnDriveLink   String?
  type           EvidenceType
  reason         String?
  rawReference   String?
  uploadedById   String?
  manifestId     String?
  returnItemId   String?
  claimReason    String?
  claimSubReason String?
  createdAt      DateTime     @default(now())

  manifest     Manifest?   @relation(fields: [manifestId], references: [id])
  returnItem   ReturnItem? @relation(fields: [returnItemId], references: [lpn])
  user         User?       @relation(fields: [uploadedById], references: [id])
}

model Alert {
  id           String     @id @default(uuid())
  level        AlertLevel
  type         String     // e.g. "SLA_BREACH", "GHOST_DELIVERY", "CLAIM_STALLED", "MISSING_ITEMS"
  title        String
  description  String
  manifestId   String?
  targetUserId String?
  resolved     Boolean    @default(false)
  resolvedById String?
  resolvedAt   DateTime?
  resolution   String?
  createdAt    DateTime   @default(now())

  manifest     Manifest?  @relation(fields: [manifestId], references: [id])
  targetUser   User?      @relation("AlertTarget", fields: [targetUserId], references: [id])
  resolvedBy   User?      @relation("AlertResolver", fields: [resolvedById], references: [id])
}

model AlertSopStep {
  id          String   @id @default(uuid())
  alertType   String   // matches Alert.type, e.g. "SLA_BREACH"
  stepOrder   Int
  instruction String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Amazon removal orders (raw portal/table import)
model AMZRemovalOrder {
  orderId             String    @id @map("order-id")
  requestDate         DateTime? @map("request-date")
  orderSource         String?   @map("order-source")
  orderType           String?   @map("order-type")
  serviceSpeed        String?   @map("service-speed")
  orderStatus         String?   @map("order-status")
  lastUpdatedDate     DateTime? @map("last-updated-date")
  sku                 String?   @map("sku")
  fnsku               String?   @map("fnsku")
  disposition         String?   @map("disposition")
  requestedQuantity   Int?      @map("requested-quantity")
  cancelledQuantity   Int?      @map("cancelled-quantity")
  disposedQuantity    Int?      @map("disposed-quantity")
  shippedQuantity     Int?      @map("shipped-quantity")
  inProcessQuantity   Int?      @map("in-process-quantity")
  removalFee          Float?    @map("removal-fee")
  currency            String?   @map("currency")

  @@map("AMZ_removal_orders")
}

// Amazon removal shipments (per-shipment rows)
model AMZRemovalShipment {
  id                String    @id @default(uuid())
  requestDate       DateTime? @map("request-date")
  orderId           String?   @map("order-id")
  shipmentDate      DateTime? @map("shipment-date")
  sku               String?   @map("sku")
  fnsku             String?   @map("fnsku")
  disposition       String?   @map("disposition")
  shippedQuantity   Int?      @map("shipped-quantity")
  carrier           String?   @map("carrier")
  trackingNumber    String?   @map("tracking-number")
  shipmentStatus    String?   @map("shipment-status")

  @@map("AMZ_removal_shipments")
}

// Amazon reimbursements table import
model AMZReimbursement {
  reimbursementId               String   @id @map("reimbursement-id")
  approvalDate                  DateTime? @map("approval-date")
  caseId                        String?  @map("case-id")
  amazonOrderId                 String?  @map("amazon-order-id")
  reason                        String?  @map("reason")
  sku                           String?  @map("sku")
  fnsku                         String?  @map("fnsku")
  asin                          String?  @map("asin")
  productName                   String?  @map("product-name")
  condition                     String?  @map("condition")
  currencyUnit                  String?  @map("currency-unit")
  amountPerUnit                 Float?   @map("amount-per-unit")
  amountTotal                   Float?   @map("amount-total")
  quantityReimbursedCash        Int?     @map("quantity-reimbursed-cash")
  quantityReimbursedInventory   Int?     @map("quantity-reimbursed-inventory")
  quantityReimbursedTotal       Int?     @map("quantity-reimbursed-total")
  originalReimbursementId       String?  @map("original-reimbursement-id")
  originalReimbursementType     String?  @map("original-reimbursement-type")

  @@map("AMZ_reimbursements")
}

// Amazon customer returns (raw LPN-level rows)
model AMZCustomerReturn {
  lpn                     String   @id @map("license-plate-number")
  returnDate              DateTime? @map("return-date")
  orderId                 String?  @map("order-id")
  sku                     String?  @map("sku")
  asin                    String?  @map("asin")
  fnsku                   String?  @map("fnsku")
  productName             String?  @map("product-name")
  quantity                Int?     @map("quantity")
  fulfillmentCenterId     String?  @map("fulfillment-center-id")
  detailedDisposition     String?  @map("detailed-disposition")
  reason                  String?  @map("reason")
  customerComments        String?  @map("customer-comments")
  removalOrderType        String?  @map("removal-order-type")

  @@map("AMZ_customer_returns")
}
